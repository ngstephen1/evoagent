{
  "name": "VT ARC EvoAgent",
  "context": ".",
  "protocol": "sftp",
  "host": "tinkercliffs1.arc.vt.edu",
  "port": 22,
  "username": "<YOUR_VT_PID>",
  "remotePath": "/home/<YOUR_VT_PID>/temp/evoagent",
  "privateKeyPath": "~/.ssh/arc",
  "uploadOnSave": false,
  "useTempFile": false,
  "openSsh": true,
  "ignore": [
    ".vscode",
    ".vscode/**",
    ".git/**",
    ".git",
    ".DS_Store",
    "**/.DS_Store",
    ".venv",
    ".venv/**",
    "**/.venv/**",
    "venv",
    "venv/**",
    "**/venv/**",
    "env",
    "env/**",
    "__pycache__",
    "__pycache__/**",
    "**/__pycache__/**",
    "data/raw/**",
    "data/interim/**",
    "data/processed/**",
    "**/.pytest_cache/**",
    "**/.mypy_cache/**",
    "**/.ruff_cache/**",
    "assignment03/runs/**",
    "runs/**",
    "outputs/**",
    "logs/**",
    "**/.cache/**",
    "**/hf_cache/**",
    "**/.hf_cache/**",
    "**/huggingface/**",
    "**/.huggingface/**",
    "**/models/**",
    "**/checkpoints/**",
    "**/*.safetensors",
    "**/*.bin",
    "**/*.pt",
    "**/*.pth",
    "**/*.ckpt",
    "**/*.tar",
    "**/*.tar.gz",
    "**/*.tgz",
    "**/*.zip",
    "**/*.7z"
  ]
}
